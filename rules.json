{
  "version": "1.1.1",
  "updatedAt": "2026-04-11T00:00:00Z",
  "categories": [
    {
      "name": "Art & Illustration",
      "rules": [
        {
          "id": "builtin_pixiv",
          "name": "Pixiv",
          "hostPattern": "*.pixiv.net",
          "enabled": true,
          "imageSelector": "img[src*=\"i.pximg.net\"]",
          "minWidth": 0,
          "minHeight": 0,
          "excludePatterns": ["/common/", "/user-profile/"],
          "urlTransforms": [
            { "from": "custom-thumb", "to": "img-master" },
            { "from": "c/250x250_80_a2/", "to": "" },
            { "from": "c/540x540_70/", "to": "" },
            { "from": "_custom1200", "to": "_master1200" },
            { "from": "_square1200", "to": "_master1200" }
          ]
        },
        {
          "id": "builtin_artstation",
          "name": "ArtStation",
          "hostPattern": "*.artstation.com",
          "enabled": true,
          "imageSelector": "img.gallery-grid-image, .project-image img",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["/profile/", "/cover/", "avatar"]
        },
        {
          "id": "builtin_deviantart",
          "name": "DeviantArt",
          "hostPattern": "*.deviantart.com",
          "enabled": true,
          "imageSelector": "img[fetchpriority=\"high\"], img.dev-content-full, .dev-view-deviation img",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["/avatars/"]
        },
        {
          "id": "builtin_behance",
          "name": "Behance",
          "hostPattern": "*.behance.net",
          "enabled": true,
          "imageSelector": "img.bf-slideshow-img, .project-module-image img",
          "minWidth": 200,
          "minHeight": 200,
          "excludePatterns": ["profile_photos", "avatar"]
        }
      ]
    },
    {
      "name": "Photography",
      "rules": [
        {
          "id": "builtin_flickr",
          "name": "Flickr",
          "hostPattern": "*.flickr.com",
          "enabled": true,
          "imageSelector": "img.main-photo, .photo-well-scrappy-view img",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["/buddyicons/", "/profile_pic/"]
        },
        {
          "id": "builtin_500px",
          "name": "500px",
          "hostPattern": "*.500px.com",
          "enabled": true,
          "imageSelector": "img[class*=\"photo\"], img[class*=\"Photo\"]",
          "minWidth": 200,
          "minHeight": 200,
          "excludePatterns": ["avatar", "profile"]
        },
        {
          "id": "builtin_unsplash",
          "name": "Unsplash",
          "hostPattern": "unsplash.com",
          "enabled": true,
          "imageSelector": "figure img, [data-test=\"photo-grid-masonry-img\"] img",
          "minWidth": 200,
          "minHeight": 200,
          "excludePatterns": ["profile_images", "profile-picture"]
        },
        {
          "id": "builtin_pexels",
          "name": "Pexels",
          "hostPattern": "*.pexels.com",
          "enabled": true,
          "imageSelector": "img[class*=\"photo\"], img[class*=\"PhotoItem\"]",
          "minWidth": 200,
          "minHeight": 200,
          "excludePatterns": ["avatar"]
        },
        {
          "id": "builtin_vsco",
          "name": "VSCO",
          "hostPattern": "vsco.co",
          "enabled": true,
          "imageSelector": "img[class*=\"image\"], img[class*=\"Image\"]",
          "minWidth": 200,
          "minHeight": 200,
          "excludePatterns": ["avatar", "profile"]
        },
        {
          "id": "builtin_bing_ioliu",
          "name": "Bing Wallpaper (ioliu.cn)",
          "hostPattern": "bing.ioliu.cn",
          "enabled": true,
          "imageSelector": "img[fetchpriority=\"high\"]",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": [],
          "urlTransforms": [
            { "from": "&w=800&h=450", "to": "" }
          ]
        }
      ]
    },
    {
      "name": "Social Media",
      "rules": [
        {
          "id": "builtin_x",
          "name": "X (x.com)",
          "hostPattern": "x.com",
          "enabled": true,
          "imageSelector": "img[src*=\"pbs.twimg.com/media\"]",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["profile_images", "profile_banners"]
        },
        {
          "id": "builtin_reddit",
          "name": "Reddit",
          "hostPattern": "*.reddit.com",
          "enabled": true,
          "imageSelector": "img[src*=\"preview.redd.it\"], img[src*=\"i.redd.it\"]",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["snoomoji", "icon", "avatar", "banner"]
        },
        {
          "id": "builtin_tumblr",
          "name": "Tumblr",
          "hostPattern": "*.tumblr.com",
          "enabled": true,
          "imageSelector": ".photo-wrap img, article img",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["avatar", "icon"]
        }
      ]
    },
    {
      "name": "Image Boards & Galleries",
      "rules": [
        {
          "id": "builtin_pinterest",
          "name": "Pinterest",
          "hostPattern": "*.pinterest.com",
          "enabled": true,
          "imageSelector": "img[src*=\"i.pinimg.com\"][src*=\"originals\"], img[src*=\"i.pinimg.com\"]",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["/30x30/", "/75x75/", "/140x/", "/236x/", "favicon"]
        },
        {
          "id": "builtin_imgur",
          "name": "Imgur",
          "hostPattern": "imgur.com",
          "enabled": true,
          "imageSelector": ".post-image-container img, .image-wrap img",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["s.imgur.com", "avatar"]
        },
        {
          "id": "builtin_zerochan",
          "name": "Zerochan",
          "hostPattern": "www.zerochan.net",
          "enabled": true,
          "imageSelector": "#large img, #entry-image img",
          "minWidth": 0,
          "minHeight": 0,
          "excludePatterns": []
        },
        {
          "id": "builtin_wallhaven",
          "name": "Wallhaven",
          "hostPattern": "wallhaven.cc",
          "enabled": true,
          "imageSelector": "img[src*=\"w.wallhaven.cc/full\"], img[src*=\"th.wallhaven.cc/small\"]",
          "minWidth": 0,
          "minHeight": 0,
          "excludePatterns": [],
          "urlTransformPipeline": "replace('th.wallhaven.cc/small','w.wallhaven.cc/full') | lastafter('/', 'wallhaven-')",
          "urlExtFallbacks": ["png"]
        }
      ]
    },
    {
      "name": "Anime & Manga",
      "rules": [
        {
          "id": "builtin_myanimelist",
          "name": "MyAnimeList",
          "hostPattern": "myanimelist.net",
          "enabled": true,
          "imageSelector": "img.lazyloaded[data-src*=\"cdn.myanimelist.net\"]",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": []
        },
        {
          "id": "builtin_anilist",
          "name": "AniList",
          "hostPattern": "anilist.co",
          "enabled": true,
          "imageSelector": ".cover-wrap img, .list-preview-wrap img",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["avatar"]
        },
        {
          "id": "builtin_nicovideo",
          "name": "Niconico Seiga",
          "hostPattern": "seiga.nicovideo.jp",
          "enabled": true,
          "imageSelector": "img.mg_image, #illust_area img",
          "minWidth": 0,
          "minHeight": 0,
          "excludePatterns": []
        }
      ]
    },
    {
      "name": "Movie & TV",
      "rules": [
        {
          "id": "builtin_themoviedb",
          "name": "The Movie Database (TMDb)",
          "hostPattern": "www.themoviedb.org",
          "enabled": true,
          "imageSelector": "img[src*=\"image.tmdb.org\"]",
          "minWidth": 100,
          "minHeight": 100,
          "excludePatterns": ["gravatar"],
          "urlTransforms": [
            { "from": "w220_and_h330_face", "to": "original" },
            { "from": "w440_and_h660_face", "to": "original" },
            { "from": "w300_and_h450_face", "to": "original" },
            { "from": "w600_and_h900_bestv2", "to": "original" }
          ]
        }
      ]
    },
    {
      "name": "Stock & Microstock",
      "rules": [
        {
          "id": "builtin_shutterstock",
          "name": "Shutterstock",
          "hostPattern": "*.shutterstock.com",
          "enabled": true,
          "imageSelector": "img[src*=\"shutterstock\"]:not([class*=\"logo\"])",
          "minWidth": 200,
          "minHeight": 200,
          "excludePatterns": ["icon", "logo", "contributor_avatar"]
        },
        {
          "id": "builtin_gettyimages",
          "name": "Getty Images",
          "hostPattern": "*.gettyimages.com",
          "enabled": true,
          "imageSelector": "img[data-asset-id], .mosaic-asset-comp img",
          "minWidth": 200,
          "minHeight": 200,
          "excludePatterns": ["logo", "icon"]
        }
      ]
    }
  ]
}
